# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/medical_store_db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Store Config
STORE_NAME=SHREE MEDICAL STORE
STORE_ADDRESS=Main Road, Your City
STORE_PHONE=1234567890
STORE_GSTIN=

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
